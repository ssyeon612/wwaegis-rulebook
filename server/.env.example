# LLM provider 선택 — 기본은 오프라인 규칙기반(키 불필요)
# ruleBased | local | gemini | claude
LLM_PROVIDER=ruleBased

# 진짜 온프레미스(권장) — 사내 자체 호스팅 (Ollama/vLLM 등). 데이터 외부 반출 없음.
LOCAL_LLM_URL=http://localhost:11434
LOCAL_LLM_MODEL=gemma2

# 클라우드 — 폐쇄망 정책(F1-6) 위배 소지. 준법 승인 후에만 사용.
GEMINI_API_KEY=
# gemini-2.0-flash·2.5-flash는 신규 키에서 막힘(쿼터 0 / 신규 사용자 차단). latest 별칭 권장.
GEMINI_MODEL=gemini-flash-latest
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-5

PORT=4300

# 국가법령정보센터 OPEN API — open.law.go.kr 신청 후 발급받은 이메일 ID
LAW_API_OC=

# 법령 자동 점검 주기 (cron · 기본 매일 04:00)
LAW_CHECK_CRON=30 6 * * *
